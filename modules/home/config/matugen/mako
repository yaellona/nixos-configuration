anchor=top-right
width=300
height=500
padding=10
margin=10,10,10,10
border-size=3
border-radius=10
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=1

background-color={{ colors.surface_container.dark.hex }}
text-color={{ colors.on_surface.dark.hex }}
border-color={{ colors.outline.dark.hex }}
progress-color={{ colors.primary.dark.hex }}

[urgency=low]
border-color={{ colors.tertiary.dark.hex }}

[urgency=normal]
border-color={{ colors.primary.dark.hex }}

[urgency=high]
default-timeout=0
border-color={{ colors.error.dark.hex }}

[urgency=critical]
background-color={{ colors.error_container.dark.hex }}
text-color={{ colors.on_error_container.dark.hex }}
border-color={{ colors.error.dark.hex }}

[category=mpd]
default-timeout=2000
group-by=category

[mode=do-not-disturb]
invisible=1
